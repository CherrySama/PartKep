<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.5 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <!-- PartKep 新增材质 -->
    <material name="mat_table"  rgba="0.75 0.60 0.42 1"/>
    <material name="mat_cup"    rgba="0.90 0.50 0.20 1"/>
    <material name="mat_handle" rgba="0.70 0.30 0.10 1"/>
    <material name="mat_tray"   rgba="0.45 0.65 0.50 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- 固定场景相机：斜上方俯视桌面 -->
    <camera name="scene_cam" pos="1.3 -0.5 1.1"
            xyaxes="0.766 0.643 0  -0.286 0.340 0.896"/>

    <!-- 桌子：桌面 z=0.4（半高0.2，pos.z=0.2） -->
    <geom name="table" type="box" size="0.3 0.4 0.2"
          pos="0.5 0 0.2" material="mat_table"
          contype="1" conaffinity="1"/>

    <!--
      杯子（freejoint，可被 weld 约束拾起）
      杯子中心 z=0.45（桌面0.4 + cylinder半高0.05）
      关键点 site 颜色：红=把手 绿=杯身 蓝=杯口
    -->
    <body name="cup" pos="0.5 0.05 0.45">
      <freejoint name="cup_free"/>
      <geom name="cup_body"   type="cylinder" size="0.04 0.05"
            pos="0 0 0"      material="mat_cup"    mass="0.2"
            contype="1" conaffinity="1"/>
      <geom name="cup_handle" type="box"      size="0.015 0.025 0.035"
            pos="0.055 0 0"  material="mat_handle" mass="0.05"
            contype="1" conaffinity="1"/>
      <!-- 把手外表面：cylinder_r(0.04) + handle_half_x*2(0.03) = 0.07 -->
      <site name="kp_handle" pos="0.07 0 0"   size="0.007" rgba="1 0 0 1"/>
      <!-- 杯身侧面（-y方向，面向相机）：cylinder_r + 2mm = 0.042 -->
      <site name="kp_body"   pos="0 -0.042 0" size="0.007" rgba="0 1 0 1"/>
      <!-- 杯口顶面上方 2mm：half_height(0.05) + 0.002 = 0.052 -->
      <site name="kp_rim"    pos="0 0 0.052"  size="0.007" rgba="0 0 1 1"/>
    </body>

    <!-- 托盘（静态 place 目标）：黄色 site 标记放置点 -->
    <body name="tray" pos="0.5 -0.2 0.405">
      <geom name="tray_surface" type="box" size="0.08 0.08 0.005"
            pos="0 0 0" material="mat_tray"
            contype="1" conaffinity="1"/>
      <site name="kp_tray_surface" pos="0 0 0.007" size="0.007" rgba="1 1 0 1"/>
    </body>

  </worldbody>
  <!-- weld 约束：初始 inactive，WELD 状态时由 mujoco_env.py 激活 -->
  <equality>
    <weld name="cup_weld" body1="cup" body2="hand" active="false" solref="0.01 1"/>
  </equality>

</mujoco>