<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.5 0 0.4" extent="1"/>

  <!-- 更稳定的模拟参数 -->
  <option timestep="0.001" 
          solver="Newton" 
          iterations="200" 
          tolerance="1e-9"
          integrator="Euler"
          cone="pyramidal"/>   <!-- pyramidal 通常比 elliptic 更稳定 -->

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="mat_table"  rgba="0.75 0.60 0.42 1"/>
    <material name="mat_cup"    rgba="0.90 0.50 0.20 1"/>
    <material name="mat_handle" rgba="0.70 0.30 0.10 1"/>
    <material name="mat_tray"   rgba="0.45 0.65 0.50 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>

    <!-- 地面 + 桌子（加强接触参数） -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"
          solref="0.03 1" solimp="0.9 0.95 0.001"/>

    <geom name="table" type="box" size="0.3 0.4 0.2"
          pos="0.5 0 0.2" material="mat_table"
          solref="0.03 1" solimp="0.9 0.95 0.001"
          contype="1" conaffinity="1"/>

    <!-- 杯子（进一步软化接触 + 更高初始位置） -->
    <body name="cup" pos="0.5 0.05 0.46">
      <joint type="free" name="cup_free" damping="0.1"/>
      
      <geom name="cup_body"   type="cylinder" size="0.04 0.05"
            pos="0 0 0"      material="mat_cup"    mass="0.15"
            solref="0.03 1"  solimp="0.96 0.99 0.0005"
            margin="0.001"
            contype="1" conaffinity="1"/>

      <geom name="cup_handle" type="box"      size="0.015 0.015 0.035"
            pos="0 0.055 0"  material="mat_handle" mass="0.01"
            solref="0.03 1"  solimp="0.96 0.99 0.0005"
            margin="0.001"
            contype="1" conaffinity="1"/>

      <site name="kp_handle" pos="0 0.07 0"   size="0.007" rgba="1 0 0 0"/>
      <site name="kp_body"   pos="0 -0.042 0" size="0.007" rgba="0 1 0 0"/>
      <site name="kp_rim"    pos="0 0 0.052"  size="0.007" rgba="0 0 1 0"/>
    </body>

    <!-- 托盘 -->
    <body name="tray" pos="0.5 -0.2 0.406">
      <geom name="tray_surface" type="box" size="0.08 0.08 0.005"
            pos="0 0 0" material="mat_tray"
            solref="0.03 1" solimp="0.9 0.95 0.001"
            contype="1" conaffinity="1"/>
      <site name="kp_tray_surface" pos="0 0 0.007" size="0.007" rgba="1 1 0 1"/>
    </body>

  </worldbody>

  <!-- weld 约束（软化） -->
  <equality>
    <weld name="cup_weld" body1="cup" body2="hand" active="false" 
          solref="0.02 1" solimp="0.95 0.99 0.001"/>
  </equality>

</mujoco>